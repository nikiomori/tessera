# Tessera — sample environment file.
# Copy to `.env` and tweak before running with docker compose.

# Require an API key on every /api/* request.
# Leave unset for an unauthenticated self-host instance.
# TESSERA_API_KEY=replace-with-a-long-random-string

# Per-IP request limit per minute. 0 = disabled (default).
# Set to e.g. 120 if exposing the API to the public internet.
TESSERA_RATE_LIMIT_PER_MIN=0

# Comma-separated list of allowed CORS origins, or `*` for any.
# TESSERA_CORS_ORIGINS=https://qr.example.com,https://www.example.com

# Maximum number of items in a single /api/batch request.
# TESSERA_MAX_BATCH_ITEMS=200
